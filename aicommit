#!/usr/bin/env bash

# Summarize git changes with Fabric
# Usage: aicommit (automatically detect changed files)

set -e

FABRIC_BIN="$HOME/.local/bin/fabric"

if [[ ! -x "$FABRIC_BIN" ]]; then
  echo "Error: fabric hasn't been properly installed"
  exit 1
fi

# Get the list of modified files (unstaged)
FILES=$(git diff --name-only)

# Exit if there are no changes
if [[ -z "$FILES" ]]; then
  echo "🌱 No changes to summarise..."
  exit 0
fi

# Get the diff of changed files to pass to Fabric
DIFF_OUTPUT=$(git diff)
COMMIT_MESSAGE=$(echo "$DIFF_OUTPUT" | "$FABRIC_BIN" -p summarize_git_diff)

echo ""
echo "💾 Committing changes with message:"
echo "-----------------------------------"
echo "$COMMIT_MESSAGE"
echo "-----------------------------------"
echo ""

echo "$FILES" | xargs git add
git commit -m "$COMMIT_MESSAGE"
